<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="mail_template_sparkle_booking_confirmation" model="mail.template">
        <field name="name">Sparkle Booking Confirmation</field>
        <field name="model_id" ref="model_sparkle_booking"/>
        <field name="subject">Your Sparkle booking is confirmed</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Hello <t t-out="object.customer_name"/>,</p>
                <p>Your cleaning service booking has been confirmed.</p>
                <ul>
                    <li><strong>Service:</strong> <t t-out="object.product_id.display_name"/></li>
                    <li><strong>Date/Time:</strong> <t t-out="format_datetime(object.booking_start)"/></li>
                    <li><strong>Location:</strong> <t t-out="object.location or 'Not provided'"/></li>
                </ul>
                <p>
                    <a t-att-href="object.get_download_url()">Download calendar invite</a>
                </p>
                <p>Thank you for booking with Sparkle Cleaning Team.</p>
            </div>
        </field>
    </record>
</odoo>
