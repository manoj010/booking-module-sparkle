<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="sparkle_booking_service_view_tree" model="ir.ui.view">
        <field name="name">sparkle.booking.service.product.list</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="categ_id"/>
                <field name="list_price"/>
                <field name="sparkle_duration_minutes"/>
                <field name="sparkle_appointment_type_id"/>
                <field name="sparkle_bookable_service"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="sparkle_booking_service_view_kanban" model="ir.ui.view">
        <field name="name">sparkle.booking.service.product.kanban</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban default_group_by="categ_id" class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="image_128"/>
                <field name="categ_id"/>
                <field name="list_price"/>
                <field name="sparkle_duration_minutes"/>
                <field name="sparkle_appointment_type_id"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <img t-att-src="kanban_image('product.template', 'image_128', record.id.raw_value)" alt="Service"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong class="o_kanban_record_title">
                                <field name="name"/>
                            </strong>
                            <div>
                                <field name="categ_id"/>
                            </div>
                            <div>
                                <span>Price: </span><field name="list_price"/>
                            </div>
                            <div>
                                <span>Duration: </span><field name="sparkle_duration_minutes"/><span> min</span>
                            </div>
                            <div>
                                <span>Appointment: </span><field name="sparkle_appointment_type_id"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="sparkle_booking_service_view_form" model="ir.ui.view">
        <field name="name">sparkle.booking.service.product.form</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_sparkle_appointment_type" type="object" string="Generate/Sync Appointment" class="btn-primary" invisible="not sparkle_bookable_service"/>
                    <button name="action_open_sparkle_appointment_type" type="object" string="Open Appointment Type" invisible="not sparkle_appointment_type_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_sparkle_appointment_type" type="object" class="oe_stat_button" icon="fa-calendar" invisible="not sparkle_appointment_type_id">
                            <field name="sparkle_appointment_type_id" widget="statinfo" string="Appointment"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="image_1920" widget="image" class="oe_avatar"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="categ_id"/>
                            <field name="description_sale"/>
                            <field name="sparkle_icon_class"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="sale_ok"/>
                            <field name="purchase_ok"/>
                            <field name="list_price"/>
                            <field name="sparkle_duration_minutes"/>
                            <field name="sparkle_appointment_type_id"/>
                            <field name="sparkle_bookable_service"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sparkle_booking_service_action" model="ir.actions.act_window">
        <field name="name">Service Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type', '=', 'service'), ('sale_ok', '=', True), ('sparkle_bookable_service', '=', True)]</field>
        <field name="context">{'active_test': False, 'default_type': 'service', 'default_sale_ok': True, 'default_purchase_ok': False, 'default_sparkle_bookable_service': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the Odoo service products customers can book.
            </p>
            <p>
                Add images, categories, pricing, and appointment settings here. These products appear dynamically in the website booking flow.
            </p>
        </field>
    </record>

    <record id="sparkle_booking_view_tree" model="ir.ui.view">
        <field name="name">sparkle.booking.list</field>
        <field name="model">sparkle.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="customer_name"/>
                <field name="product_id"/>
                <field name="appointment_type_id"/>
                <field name="crm_lead_id"/>
                <field name="booking_start"/>
                <field name="booking_stop"/>
                <field name="price"/>
                <field name="payment_status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="sparkle_booking_view_form" model="ir.ui.view">
        <field name="name">sparkle.booking.form</field>
        <field name="model">sparkle.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm_booking" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_done" type="object" string="Mark Done" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_cancel_booking" type="object" string="Cancel" invisible="state in ('cancelled', 'done')"/>
                    <button name="action_create_or_update_crm_lead" type="object" string="Create/Update CRM Lead"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_customer" type="object" class="oe_stat_button" icon="fa-user" invisible="not partner_id">
                            <field name="partner_id" widget="statinfo" string="Customer"/>
                        </button>
                        <button name="action_open_appointment_event" type="object" class="oe_stat_button" icon="fa-calendar" invisible="not calendar_event_id">
                            <field name="calendar_event_id" widget="statinfo" string="Appointment"/>
                        </button>
                        <button name="action_open_crm_lead" type="object" class="oe_stat_button" icon="fa-handshake-o" invisible="not crm_lead_id">
                            <field name="crm_lead_id" widget="statinfo" string="CRM Lead"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="partner_id"/>
                            <field name="customer_name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="booking_start"/>
                            <field name="booking_stop"/>
                            <field name="appointment_type_id"/>
                            <field name="calendar_event_id"/>
                            <field name="crm_lead_id"/>
                            <field name="price"/>
                            <field name="payment_status"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Message">
                            <field name="message"/>
                        </page>
                        <page string="Internal Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sparkle_booking_action" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">sparkle.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="sparkle_booking_crm_lead_action" model="ir.actions.act_window">
        <field name="name">CRM Leads</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form,calendar,pivot,graph,activity</field>
        <field name="domain">[('source_id.name', '=', 'Website Booking')]</field>
        <field name="context" eval="{'default_source_id': ref('sparkle_booking_flow.sparkle_booking_source_website')}"/>
    </record>

    <menuitem id="sparkle_booking_menu_root" name="Sparkle Booking" sequence="30"/>
    <menuitem id="sparkle_booking_menu_services" name="Service Products" parent="sparkle_booking_menu_root" action="sparkle_booking_service_action" sequence="10"/>
    <menuitem id="sparkle_booking_menu_appointments" name="Appointments" parent="sparkle_booking_menu_root" action="appointment.appointment_type_action" sequence="30"/>
    <menuitem id="sparkle_booking_menu_bookings" name="Bookings" parent="sparkle_booking_menu_root" action="sparkle_booking_action" sequence="40"/>
    <menuitem id="sparkle_booking_menu_crm_leads" name="CRM Leads" parent="sparkle_booking_menu_root" action="sparkle_booking_crm_lead_action" sequence="50"/>
</odoo>
